# ============================================
# Job Pipeline Environment Configuration
# ============================================

# Firecrawl API Key (for general job boards)
# Get yours at: https://firecrawl.dev/app
FIRECRAWL_API_KEY=fc-your-api-key-here

# Crust API Key (for LinkedIn scraping)
# Get yours at: https://getcrust.com/
# Optional but highly recommended for LinkedIn
CRUST_API_KEY=crust-your-api-key-here

# Supabase Configuration
# Get these from your Supabase project settings > API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key-or-service-role-key

# Anthropic API Key (for Claude AI CV optimization)
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# API Authentication (optional)
# Set a secret key for securing your API endpoints
API_KEY=your-secret-api-key-here

# Optional: Pipeline Configuration
MAX_JOBS_PER_RUN=50
LOG_LEVEL=INFO

# Railway deployment (auto-set by Railway)
# PORT=8000
# RAILWAY_ENVIRONMENT=production
